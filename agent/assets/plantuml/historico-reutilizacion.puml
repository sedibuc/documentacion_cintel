@startuml

skinparam backgroundColor #1a202c
skinparam defaultFontColor #d4dae6
skinparam defaultFontSize 12
skinparam arrowColor #4db8b5
skinparam ArrowFontColor #9ba5b4
skinparam ArrowFontSize 11
skinparam borderColor #2d3748
skinparam shadowing false

skinparam sequenceParticipantBorderColor #2d3748
skinparam sequenceParticipantBackgroundColor #1e2533
skinparam sequenceParticipantFontColor #f0ece3
skinparam sequenceActorBorderColor #4db8b5
skinparam sequenceActorBackgroundColor #0f3a38
skinparam sequenceActorFontColor #4db8b5
skinparam sequenceArrowColor #4db8b5
skinparam sequenceArrowFontColor #9ba5b4
skinparam sequenceLifeLineBorderColor #2d3748
skinparam sequenceDividerBackgroundColor #161b27
skinparam sequenceDividerBorderColor #2d3748
skinparam sequenceDividerFontColor #4db8b5
skinparam sequenceGroupBorderColor #2d3748
skinparam sequenceGroupBackgroundColor #161b27
skinparam sequenceGroupFontColor #9ba5b4
skinparam noteBorderColor #4db8b5
skinparam noteBackgroundColor #0c3030
skinparam noteFontColor #7fcba7
skinparam titleFontColor #f0ece3
skinparam titleFontSize 14

title <b>Flujo de reutilización de campaña</b>

actor "Usuario" as U #0f3a38
participant "Histórico" as H #1e2533
participant "Agente\nEstratégico" as AE #0f5a58
participant "Agente\nCreativo" as AC #0f5a58

U -> H : Accede al módulo de Histórico
H --> U : Muestra listado de campañas

U -> H : Aplica filtro (ej: año=2024)
H --> U : Lista filtrada de campañas

U -> H : Selecciona campaña
H --> U : Muestra estructura completa\n(Plan → Briefs → Piezas)

note over U, H
  El usuario decide reutilizar
  esta campaña como punto de partida
end note

U -> H : "Usar como base para 2025"
H -> AE : Carga contexto de campaña\n(plan, briefs, piezas anteriores)

AE --> U : Inicia conversación\ncon contexto precargado

U -> AE : Ajusta objetivo y audiencia
AE -> AC : Genera nuevos briefs\nbasados en campaña anterior

AC --> U : Nueva campaña creada\ncon base en histórico

@enduml